{
  "name": "fullstack-airbnb-clone",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.18.2",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:client": "pnpm --filter @airbnb-clone/client dev",
    "dev:server": "pnpm --filter @airbnb-clone/server start:dev",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "seed": "pnpm --filter @airbnb-clone/server seed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "concurrently": "^8.2.2"
  },
  "devDependencies": {
    "turbo": "^2.5.8"
  }
}
